# Public env
NEXT_PUBLIC_GRAPHQL_ENDPOINT=http://localhost:4000/graphql
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=replace-with-thirdweb-client-id
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=replace-with-walletconnect-project-id
NEXT_PUBLIC_SIWE_AUTH_SERVICE_URL=https://auth.giveth.io
NEXT_PUBLIC_VERCEL_ENV=local
NEXT_PUBLIC_IMPACT_GRAPH_URL=https://impact-graph.serve.giveth.io/graphql
NEXT_PUBLIC_OLD_FRONTEND_URL=https://giveth.io
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_SCHEMA_URL=../giveth-v6-core/src/schema.gql # Either point to schema.gql file in v6 core repo, e.g. '../giveth-v6-core/src/schema.gql' or local graphQL endpoint like http://localhost:4000/graphql

# Server-only env (do NOT prefix with NEXT_PUBLIC_)
# Used by /api/ai/create-project
OPENAI_API_KEY=replace-with-openai-api-key
# Optional override (defaults to gpt-5-mini)
OPENAI_MODEL=gpt-5-mini
# Optional override (defaults to https://api.openai.com)
OPENAI_BASE_URL=https://api.openai.com